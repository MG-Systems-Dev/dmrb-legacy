# DMRB Legacy — local development environment variables
# Copy to .env and fill in real values. Never commit .env.
#
# Generate SECRET_KEY:  python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# Generate SETUP_KEY:   python3 -c "import secrets; print(secrets.token_urlsafe(32))"

DATABASE_URL=postgresql://postgres:password@localhost:5432/dmrb

# Session signing secret (required in all environments)
SECRET_KEY=
# SESSION_SECRET is accepted as an alias: SESSION_SECRET= works identically

# First-admin claim key — required to complete /setup in the browser
SETUP_KEY=

# Optional: bypass all auth in local dev (never set in production)
# AUTH_DISABLED=true

# Optional: OpenAI key for the AI agent screen
# OPENAI_API_KEY=
